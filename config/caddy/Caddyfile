# Caddyfile for Homelab Standalone
# Reverse proxy to services via container names on proxy network

{
    auto_https off
    log {
        level INFO
    }
}

# Homepage - main dashboard (port 3000) - accessed via 8080
http://localhost:8080 {
    reverse_proxy http://homepage:3000
}

# Traefik Dashboard (when available) - accessed via 8090
http://localhost:8090 {
    reverse_proxy http://traefik:8080
}

# PiHole Admin - accessed via 8081
http://localhost:8081 {
    reverse_proxy http://pihole:8081
}

# Jellyfin - accessed via 8096
http://localhost:8096 {
    reverse_proxy http://jellyfin:8096
}

# Keycloak - accessed via 8080 (different path)
http://localhost:8080/keycloak* {
    reverse_proxy http://keycloak:8080
}

# Nextcloud - accessed via 8080 (different path)
http://localhost:8080/nextcloud* {
    reverse_proxy http://nextcloud:80
}

# Ollama - accessed via 11434
http://localhost:11434 {
    reverse_proxy http://ollama:11434
}

# Portainer - accessed via 9443
http://localhost:9443 {
    reverse_proxy http://portainer:9443
}

# Radarr - accessed via 7878
http://localhost:7878 {
    reverse_proxy http://radarr:7878
}

# Sonarr - accessed via 8989
http://localhost:8989 {
    reverse_proxy http://sonarr:8989
}

# Uptime Kuma - accessed via 3001
http://localhost:3001 {
    reverse_proxy http://uptime-kuma:3001
}

# Vaultwarden - accessed via 8000
http://localhost:8000 {
    reverse_proxy http://vaultwarden:8000
}
