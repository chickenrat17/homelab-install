# Caddyfile for Homelab
# Auto-reload config, serve static files, proxy to services

{
    auto_https off
}

# PiHole Admin - proxy to PiHole container
http://localhost:8081 {
    reverse_proxy http://192.168.68.95:8081
}

# Traefik Dashboard - proxy to Traefik container
http://localhost:9090 {
    reverse_proxy http://192.168.68.95:9090
}

# Caddy Admin API - proxy to Caddy's internal admin port
http://localhost:2019 {
    reverse_proxy http://localhost:2019
}

# Default response
http:// {
    respond "Caddy reverse proxy is running"
}
