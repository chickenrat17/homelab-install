# Caddyfile for Homelab Standalone
# Works without Traefik - uses container names on proxy network

{
    auto_https off
    log {
        level INFO
    }
}

http://localhost:8080 {
    reverse_proxy http://homepage:3000
}

http://localhost:8090 {
    reverse_proxy http://jellyfin:8096
}

http://localhost:8081 {
    reverse_proxy http://pihole:8081
}

http://localhost:9443 {
    reverse_proxy http://portainer:9443
}

http://localhost:11434 {
    reverse_proxy http://ollama:11434
}
