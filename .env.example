# Homelab Environment Variables
# Copy this to .env and fill in your values

# Domain for Traefik
DOMAIN=homelab.local

# ⚠️ SECURITY: Set strong passwords before installation
# These defaults are placeholders - MUST BE CHANGED

# Keycloak - Set a strong password (min 12 characters)
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_WITH_A_STRONG_PASSWORD
KEYCLOAK_ADMIN=admin

# Grafana - Set a strong password (min 12 characters)
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_WITH_A_STRONG_PASSWORD

# OpenClaw
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# Vaultwarden
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=noreply@homelab.local
SMTP_USERNAME=
SMTP_PASSWORD=

# Immich - Set a strong database password
IMMICH_DB_PASSWORD=CHANGE_ME_WITH_A_STRONG_PASSWORD

# Samba - Set a strong password for file sharing
SAMBA_PASSWORD=

# Uptime Kuma - Configure via UI after installation
# UPTIME_KUMA_NOTIFICATION_