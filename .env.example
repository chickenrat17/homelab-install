# Homelab Environment Variables
# Copy this to .env and fill in your values

# Domain for Traefik
DOMAIN=homelab.local

# ADMIN PASSWORD - set by install.sh (required)
# ADMIN_PASSWORD=

# Keycloak (use ADMIN_PASSWORD)
KEYCLOAK_ADMIN_PASSWORD=changeMe123!
KEYCLOAK_ADMIN=admin

# Grafana (use ADMIN_PASSWORD)
GF_SECURITY_ADMIN_PASSWORD=changeMe123!

# OpenClaw
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# Vaultwarden
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=noreply@homelab.local
SMTP_USERNAME=
SMTP_PASSWORD=

# Immich
IMMICH_DB_PASSWORD=immich

# Samba (network file share)
SAMBA_PASSWORD=

# Uptime Kuma (configure via UI)
# UPTIME_KUMA_NOTIFICATION_